# Byte-compiled
__pycache__/
*.py[codz]

# Packaging
build/
dist/
*.egg-info/
*.egg

# Virtualenvs
.venv/
venv/
env/

# Lab artifacts — never commit datasets or model weights
data/*
!data/.gitkeep
outputs/

# Test fixtures are generated from tests/fixtures/build_*.py
# (auto-built on demand by tests/conftest.py), so the image/Arrow blobs
# are never committed — only the builder scripts are. Ignore every generated
# fixture subdir; the .py builders at the fixtures root stay tracked.
tests/fixtures/*/

# Experiment tracking & secrets
wandb/
.env

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
